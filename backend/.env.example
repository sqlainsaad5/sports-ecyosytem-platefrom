PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/sports_ecosystem
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
HOLD_MINUTES=5
# Admin login: email must match this user in DB (run npm run seed:admin once). Password is ONLY here — not stored in MongoDB.
ADMIN_EMAIL=admin@sports-ecosystem.local
ADMIN_PASSWORD=ChangeMeAdmin123!
